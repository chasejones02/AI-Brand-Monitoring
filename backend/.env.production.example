# backend/.env.production.example
# ===============================================================
# PRODUCTION backend env — set these in your HOST's dashboard
# (Railway → Variables, or Render → Environment). Do NOT commit real
# values and do NOT upload a .env file; type them into the host UI.
#
# IMPORTANT: config/env.ts validates ALL of these at boot. If any required
# one is missing or still a placeholder, the server REFUSES to start and
# prints which var is wrong. (PORT and SENTRY_DSN are the only optional ones.)
# ===============================================================


# --- Server ---------------------------------------------------
# DO NOT SET PORT — Railway/Render inject it automatically and env.ts reads it.
# NODE_ENV must be 'production' (enables the prod guards/warnings in env.ts).
NODE_ENV=production

# Your LIVE frontend domain (the Vercel custom domain). Drives CORS + Stripe
# success/cancel redirects. You won't know the final value until the frontend
# is deployed — set a placeholder for the first deploy, then update + redeploy.
FRONTEND_URL=https://yourdomain.com


# --- Supabase (PROD project) ----------------------------------
# Supabase dashboard → (your PROD project) → Project Settings → API
SUPABASE_URL=https://YOUR-PROD-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=__prod_anon_key__
# Service role bypasses RLS — backend host ONLY. Never in any VITE_ / frontend var.
SUPABASE_SERVICE_ROLE_KEY=__prod_service_role_key__


# --- AI provider keys -----------------------------------------
# Use PROD-only keys (separate from local dev) each with a usage cap set in the
# provider dashboard. At least one is required; the product needs all 4 for full
# platform coverage. NOTE: Anthropic now performs live web search ($10/1k
# searches) — a usage cap matters here.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=...


# --- Stripe (LIVE mode) ---------------------------------------
# Stripe dashboard in LIVE mode → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Signing secret from the LIVE webhook endpoint you create AFTER this backend
# has a public URL (Developers → Webhooks → your endpoint → Signing secret).
# This is NOT the `stripe listen` CLI secret from local dev.
STRIPE_WEBHOOK_SECRET=whsec_...

# LIVE price IDs — recreate all 4 products/prices in Live mode; test-mode IDs
# do NOT carry over. (env.ts requires all four, incl. the annual variants.)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...


# --- Error tracking (optional, recommended) -------------------
# Leave blank to disable. Surfaces background scan + webhook failures.
SENTRY_DSN=


# --- NOT SET HERE ---------------------------------------------
# SUPABASE_SMTP_* and SUPABASE_SITE_URL from .env.example are read by the
# Supabase CLI (config.toml), not this backend. Configure auth email + the
# auth Site URL in the Supabase dashboard (Authentication → URL Configuration).
