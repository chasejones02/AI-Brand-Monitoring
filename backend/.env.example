# backend/.env.example
# ---------------------------------------------------------------
# Template for backend environment variables.
# Copy this file to .env and fill in your real values.
#   cp backend/.env.example backend/.env
#
# .env is gitignored — never commit real secrets.
# Update this file whenever a new variable is added to the codebase.
# ---------------------------------------------------------------


# --- Server ---------------------------------------------------
# Port the API server listens on locally.
PORT=3001

# Frontend origin allowed through CORS.
# Change to your production domain when deploying.
FRONTEND_URL=http://localhost:5173


# --- Supabase -------------------------------------------------
# Found in: Supabase dashboard → Project Settings → API
#
# Project URL (same value used in frontend and backend)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — safe for auth middleware, limited DB access
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — full DB access, backend only, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# --- AI Platform APIs -----------------------------------------
# Only platforms with a valid key will be activated by the query engine.
# You can start with just one and add others as you scale.
#
# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity — https://www.perplexity.ai/settings/api
# Searches the web in real-time — essential for finding local/small businesses
PERPLEXITY_API_KEY=pplx-...

# Future platforms (Phase 2)
# GEMINI_API_KEY=...


# --- Stripe ---------------------------------------------------
# Found in: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from: Stripe dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from: Stripe dashboard → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...
