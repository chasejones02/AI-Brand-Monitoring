# frontend/.env.production.example
# ===============================================================
# PRODUCTION frontend env — set these in Vercel
# (Project → Settings → Environment Variables, scope: Production).
#
# Only VITE_-prefixed vars reach the browser. NEVER put a secret here
# (no service_role key, no Stripe secret). This app uses backend-redirect
# Stripe checkout, so NO Stripe publishable key is needed.
# ===============================================================


# --- Supabase (PROD project — same project as the backend) ----
# Supabase dashboard → (PROD project) → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROD-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=__prod_anon_key__


# --- Backend API ----------------------------------------------
# The PUBLIC URL of your deployed backend (Railway gives you one like
# https://your-app.up.railway.app). Set this AFTER the backend is deployed.
# No trailing slash.
VITE_API_URL=https://your-backend.up.railway.app


# --- Error tracking (optional) --------------------------------
# Use a SEPARATE Sentry project from the backend so frontend errors are scoped.
VITE_SENTRY_DSN=
