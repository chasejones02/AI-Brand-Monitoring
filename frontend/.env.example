# frontend/.env.example
# ---------------------------------------------------------------
# Template for frontend environment variables.
# Copy this file to .env and fill in your real values.
#   cp frontend/.env.example frontend/.env
#
# .env is gitignored — never commit real secrets.
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to
# the browser. Never put secret keys (service role, etc.) here.
# Update this file whenever a new variable is added to the codebase.
# ---------------------------------------------------------------


# --- Supabase -------------------------------------------------
# Found in: Supabase dashboard → Project Settings → API
# Must match the values in backend/.env (same Supabase project).
#
# Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — safe to expose in the browser, used by Supabase client
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# --- Backend API ----------------------------------------------
# URL the frontend uses to reach the backend API server.
# Change to your deployed backend URL in production.
VITE_API_URL=http://localhost:3001
